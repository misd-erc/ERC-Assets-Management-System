@using PortalDB.Models.ViewModels.Email

@model EmailViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Subject</title>
</head>
<body style="margin:0; padding:0; font-family:Segoe UI, Arial, sans-serif; background-color:#f5f7fa; color:#333;">
    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#f5f7fa; padding:40px 0;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:10px; box-shadow:0 4px 8px rgba(0,0,0,0.05); overflow:hidden;">
                    <tr>
                        <td style="background-color:#1E88E5; color:#ffffff; text-align:center; padding:20px 30px;">
                            <h1 style="margin:0; font-size:22px;">ERC-AMS Security Alert</h1>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:30px;">
                            <p style="font-size:16px;">Hello <strong>@Model.Name</strong>,</p>

                            <p style="font-size:16px; line-height:1.6;">
                                Your One-Time Password (OTP) is:
                            </p>

                            <p style="font-size:28px; text-align:center; background-color:#f0f4ff; color:#1E88E5; padding:12px 0; border-radius:8px; letter-spacing:2px; margin:20px 0;">
                                <strong>@Model.Body</strong>
                            </p>

                            <p style="font-size:16px; line-height:1.6;">
                                This OTP is valid for <strong>3 minutes</strong>. If you did not request this, please contact our support team immediately.
                            </p>

                            <p style="font-size:16px; margin-top:30px;">
                                Best regards,<br />
                                <strong>AMS Team</strong>
                            </p>
                        </td>
                    </tr>
                    <tr>
                        <td style="background-color:#f0f4ff; text-align:center; padding:15px; font-size:13px; color:#777;">
                            © @DateTime.UtcNow.Year Energy Regulatory Commission. All rights reserved.
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>